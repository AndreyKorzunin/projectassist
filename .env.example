GIGACHAT_CLIENT_ID=your_client_id_here
GIGACHAT_SECRET=your_secret_here
GIGACHAT_SCOPE=GIGACHAT_API_PERS

GIGACHAT_MODEL=GigaChat
GIGACHAT_TEMPERATURE=0.3

HOST=0.0.0.0
PORT=8000
DEBUG=True

MAX_UPLOAD_SIZE=50
ALLOWED_EXTENSIONS=.docx,.xlsx,.xls,.pdf

CORS_ORIGINS=http://localhost:8000,http://localhost:3000,http://127.0.0.1:8000

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Logging
LOG_LEVEL=INFO